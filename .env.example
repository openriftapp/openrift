# ──────────────────────────────────────────────────────────
# Shared (used by multiple containers or Docker Compose itself)
# ──────────────────────────────────────────────────────────

# User/group ID for containers that write to bind mounts (Postgres, API).
# Ensures files are owned by your host user. Find yours with: id -u / id -g
UID=1000
GID=1000

# App environment: "development" | "production" | "preview".
# - development: API returns detailed errors (stack traces, validation details).
# - production: canonical openrift.app deploy. Hides stack traces, enforces required vars.
# - preview: preview.openrift.app deploy. Same prod behavior as "production" plus
#   SEO noindex (robots meta, /robots.txt disallow, X-Robots-Tag header) so the
#   preview instance never gets indexed by search engines.
APP_ENV=development

# GHCR image tag. Set to "preview" for preview instance, "latest" for stable.
IMAGE_TAG=latest

# ──────────────────────────────────────────────────────────
# db (PostgreSQL)
# ──────────────────────────────────────────────────────────

# Database credentials. Only password needs to be changed.
POSTGRES_DB=openrift
POSTGRES_USER=openrift
POSTGRES_PASSWORD=password

# Host port for Postgres. Only affects localhost access, not inter-container communication.
DB_PORT=5432

# ──────────────────────────────────────────────────────────
# api (Hono)
# ──────────────────────────────────────────────────────────

# Connection string for the API to reach Postgres.
# In production, update the password and change localhost to db (the Compose service name).
# Always use port 5432 here — DB_PORT above only controls the host-side mapping.
DATABASE_URL=postgres://openrift:password@localhost:5432/openrift

# Host port for the API.
API_PORT=3001

# Which domains are allowed to call the API (comma-separated).
# Wildcards like *.example.com match any subdomain.
CORS_ORIGIN=https://openrift.app,https://preview.openrift.app

# Better Auth secret key. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Better Auth base URL. Set to your app's public URL.
BETTER_AUTH_URL=http://localhost:5173

# SMTP settings for email verification.
SMTP_HOST=smtp.fastmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
SMTP_USER=noreply@openrift.app
SMTP_PASS=
SMTP_FROM=OpenRift <noreply@openrift.app>

# Auto-admin: when this email registers, they are automatically made admin.
ADMIN_EMAIL=i.love@openrift.app

# OAuth — Google (https://console.cloud.google.com/ → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Discord (https://discord.com/developers/applications → OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# CardTrader API token (https://www.cardtrader.com/en/account/api).
# Required for CardTrader price refresh. Leave empty to disable.
CARDTRADER_API_TOKEN=

# Cloudflare API token + zone ID for the admin cache purge button.
# Both must be set for the purge feature to appear enabled; leave empty to disable.
#
# Create the token (https://dash.cloudflare.com/profile/api-tokens):
#   1. Create Token → Create Custom Token
#   2. Permissions: Zone → Cache Purge → Purge
#   3. Zone Resources: Include → Specific zone → <your zone>
#   4. Continue to summary → Create Token → copy the value shown once
#
# Find the zone ID on the zone's Overview page in the Cloudflare dashboard,
# in the "API" section of the right-hand sidebar (below "Zone ID").
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Price refresh crons. Set a schedule to enable, leave commented to disable.
# CardTrader also requires CARDTRADER_API_TOKEN above.
# CRON_TCGPLAYER=0 6 * * *
# CRON_CARDMARKET=15 6 * * *
# CRON_CARDTRADER=30 6 * * *

# Sentry error tracking for the API. Leave empty to disable.
SENTRY_DSN=

# Log every API request (method, path, status, duration) via Hono's logger. Set to "true" to enable.
# LOG_REQUESTS=true

# Also log request bodies for debugging. Auth endpoints (/api/auth/*) are skipped to avoid
# logging credentials. Bodies over 10KB are truncated. Set to "true" to enable.
# LOG_REQUEST_BODIES=true

# Log response bodies for debugging. Auth endpoints are skipped, non-textual content
# (images, binaries) is skipped, and bodies over 10KB are truncated. Set to "true" to enable.
# LOG_RESPONSE_BODIES=true

# Deploy lockfile path. Override to run multiple instances on the same host.
# DEPLOY_LOCKFILE=/tmp/openrift-deploy.lock

# ──────────────────────────────────────────────────────────
# web (TanStack Start)
# ──────────────────────────────────────────────────────────

# Host port for the web app (served via proxy in production).
WEB_PORT=8080

# Public origin for this deployment. Used for og:image, canonical links, sitemap, share URLs.
# Read at runtime (not baked at build time) so the same Docker image can deploy to prod and preview.
# Prod: https://openrift.app  —  Preview: https://preview.openrift.app
SITE_URL=http://localhost:5173

# Sentry error tracking for the web app (compiled in at build time). Leave empty to disable.
VITE_SENTRY_DSN=

# Auth token + org/project for source map uploads during CI builds (not needed locally).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ──────────────────────────────────────────────────────────
# Backups (configured in backup/.env, see backup/.env.example)
# ──────────────────────────────────────────────────────────
