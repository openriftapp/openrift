# Database name. No change needed.
POSTGRES_DB=openrift

# Database user. No change needed.
POSTGRES_USER=openrift

# Database password. Use a strong generated value in production.
POSTGRES_PASSWORD=password

# Connection string used by the API.
# In production, update the password and change localhost to db (the Compose service name).
# Always use port 5432 here — DB_PORT below only controls the host-side mapping.
DATABASE_URL=postgres://openrift:password@localhost:5432/openrift

# User/group ID for containers that write to bind mounts (Postgres, API).
# Ensures files are owned by your host user. Find yours with: id -u / id -g
UID=1000
GID=1000

# Host ports for Docker Compose. Only affects localhost access, not inter-container communication.
# Change these to run multiple instances on the same host.
# Main: 5432/3001/8080 (defaults), Beta: 5433/3002/8081
DB_PORT=5432
API_PORT=3001
WEB_PORT=8080

# GHCR image tag. Set to "preview" for preview instance, "latest" for stable.
IMAGE_TAG=latest

# Cron jobs (price refresh). Set CRON_ENABLED=false to disable (e.g. local dev).
# Override schedules with cron expressions (defaults: TCGPlayer 06:00 UTC, Cardmarket 06:15 UTC).
CRON_ENABLED=true
# CRON_TCGPLAYER=0 6 * * *
# CRON_CARDMARKET=15 6 * * *

# Which domains are allowed to call the API (comma-separated). No change needed.
# Wildcards like *.example.com match any subdomain.
CORS_ORIGIN=https://openrift.app,https://preview.openrift.app

# Better Auth secret key. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Better Auth base URL. Set to your app's public URL.
BETTER_AUTH_URL=http://localhost:5173
# SMTP settings for email verification.
SMTP_HOST=smtp.fastmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
SMTP_USER=noreply@openrift.app
SMTP_PASS=
SMTP_FROM=OpenRift <noreply@openrift.app>

# Auto-admin: when this email registers, they are automatically made admin.
ADMIN_EMAIL=i.love@openrift.app

# Database backups to Cloudflare R2.
# Create a separate R2 bucket (e.g. "openrift-backups") with a lifecycle rule for retention.
# Create an R2 API token with Object Read & Write for that bucket.
# Endpoint does NOT include the bucket name: https://<account-id>.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
BACKUP_S3_BUCKET=openrift-backups
BACKUP_S3_PREFIX=backups
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_ENCRYPTION_PASSWORD=
# BACKUP_SCHEDULE=@daily
# BACKUP_KEEP_DAYS=30

# OAuth — Google (https://console.cloud.google.com/ → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Discord (https://discord.com/developers/applications → OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
