{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./rpc": {
      "types": "./dist/rpc-types.d.ts",
      "default": "./src/rpc-types.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "test:watch": "vitest",
    "test:integration": "bun --env-file=../../.env run src/test/run-integration.ts",
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "start": "bun --env-file=../../.env src/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.2.3",
    "@openrift/shared": "workspace:*",
    "better-auth": "1.5.6",
    "croner": "10.0.1",
    "hono": "4.12.9",
    "hono-rate-limiter": "0.5.3",
    "kysely": "0.28.14",
    "kysely-postgres-js": "3.0.0",
    "nodemailer": "8.0.4",
    "postgres": "3.4.8",
    "sharp": "0.34.5",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/nodemailer": "7.0.11",
    "@vitest/coverage-v8": "4.1.1",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  }
}
