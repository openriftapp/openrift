{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./rpc": {
      "types": "./dist/rpc-types.d.ts",
      "default": "./src/rpc-types.ts"
    }
  },
  "scripts": {
    "test": "bun --env-file=../../.env test $(find src -name '*.test.ts' ! -name '*.integration.test.ts')",
    "test:coverage": "bun --env-file=../../.env test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=./coverage/unit $(find src -name '*.test.ts' ! -name '*.integration.test.ts') && COVERAGE=1 bun --env-file=../../.env run src/test/run-integration.ts",
    "test:watch": "bun --env-file=../../.env --watch test $(find src -name '*.test.ts' ! -name '*.integration.test.ts')",
    "test:integration": "bun --env-file=../../.env run src/test/run-integration.ts",
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "start": "bun --env-file=../../.env src/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@hono/zod-validator": "0.5.0",
    "@openrift/shared": "workspace:*",
    "better-auth": "1.5.5",
    "croner": "10.0.1",
    "hono": "4.12.7",
    "hono-rate-limiter": "0.5.3",
    "kysely": "0.28.11",
    "kysely-postgres-js": "3.0.0",
    "nodemailer": "8.0.2",
    "postgres": "3.4.8",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/nodemailer": "7.0.11",
    "typescript": "5.9.3"
  }
}
