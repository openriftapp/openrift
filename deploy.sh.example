#!/usr/bin/env bash
set -euo pipefail

# Deploy by pulling pre-built images from GHCR and restarting services.
# The IMAGE_TAG in .env controls which version runs (latest, preview, v1.2.3).

cd "$(dirname "$0")"

LOCKFILE="${DEPLOY_LOCKFILE:-/tmp/openrift-deploy.lock}"
if [ -f "$LOCKFILE" ]; then
  echo "Deploy already running (lockfile: $LOCKFILE), exiting."
  exit 1
fi
touch "$LOCKFILE"

# On normal exit, remove lockfile
trap 'rm -f "$LOCKFILE"' EXIT
# On signal (SSH disconnect, Ctrl-C, kill), kill all child processes first
trap 'trap - INT TERM HUP; kill -- -$$ 2>/dev/null' INT TERM HUP

echo "==> Ensuring data directories exist..."
mkdir -p data/postgres card-images

echo "==> Pulling images..."
pull_retries=3
for i in $(seq 1 "$pull_retries"); do
  if docker compose pull; then
    break
  fi
  if [ "$i" -eq "$pull_retries" ]; then
    echo "Image pull failed after $pull_retries attempts, aborting."
    exit 1
  fi
  wait=$((i * 10))
  echo "Pull attempt $i/$pull_retries failed, retrying in ${wait}s..."
  sleep "$wait"
done

echo "==> Restarting services..."
docker compose up -d

echo "==> Cleaning up old images..."
docker image prune -f

echo "==> Done. Current status:"
docker compose ps
