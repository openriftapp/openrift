{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "apps/api": {
      "entry": ["src/app.ts"],
      "ignore": ["src/**/*.test.ts", "src/**/*.integration.test.ts", "src/test/**"]
    },
    "apps/web": {
      "entry": [
        "src/worker.ts",
        "src/routes/**/*.tsx",
        "src/components/cards/card-detail/index.tsx"
      ],
      "ignore": ["src/env.d.ts", "src/components/ui/**"]
    },
    "packages/shared": {
      "ignore": ["src/**/*.test.ts", "src/**/*.integration.test.ts", "src/test/**"]
    }
  },
  "ignoreBinaries": ["wait"]
}
