{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Top 10 Queries by Total Time",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 600 }
            ]
          },
          "custom": {
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total time (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Mean time (s)" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "targets": [
        {
          "expr": "topk(10, pg_stat_statements_seconds_total)",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "user": true,
              "datname": true
            },
            "renameByName": {
              "query": "Query",
              "queryid": "ID",
              "Value": "Total time (s)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Total time (s)", "desc": true }] }
        }
      ]
    },
    {
      "title": "Top 10 Queries by Mean Time",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "fieldConfig": {
