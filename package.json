{
  "name": "openrift",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "bun run dev:web & bun run dev:api & wait",
    "dev:web": "turbo run dev --filter=web",
    "format": "oxfmt",
    "lint": "turbo run build && bun run lint:oxlint && bun run lint:oxfmt",
    "lint:oxlint": "oxlint --deny-warnings",
    "lint:oxfmt": "oxfmt ./apps ./packages --check",
    "lefthook": "lefthook",
    "db:migrate": "bun run --cwd packages/shared db:migrate",
    "db:cleanup": "bun --env-file=.env scripts/db-cleanup.ts",
    "db:rollback": "bun run --cwd packages/shared db:rollback",
    "make-admin": "bun run --cwd packages/shared make-admin --",
    "dev:api": "bun --env-file=.env --watch apps/api/src/index.ts | bunx pino-pretty",
    "routes:generate": "bun run --cwd apps/web routes:generate",
    "preview": "turbo run build && (bun run --cwd apps/api start & bun run --cwd apps/web preview & wait)",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage && mkdir -p coverage && lcov-result-merger '{apps,packages}/*/coverage/**/lcov.info' coverage/lcov.info",
    "test:watch:web": "bun run --cwd apps/web test:watch",
    "test:watch:api": "bun run --cwd apps/api test:watch",
    "test:watch:shared": "bun run --cwd packages/shared test:watch",
    "test:integration": "turbo run test:integration",
    "knip": "knip",
    "postinstall": "test -n \"$CI\" || test -n \"$DOCKER_CONTAINER\" || env | grep -q ^DEPENDABOT || lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@commitlint/types": "20.4.4",
    "knip": "5.86.0",
    "lcov-result-merger": "5.0.1",
    "lefthook": "2.1.4",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "syncpack": "14.2.0",
    "turbo": "2.8.16"
  },
  "overrides": {
    "//": "Patch vulnerable transitive deps. Run `bun audit` after removing any to check if still needed.",
    "// hono, @hono/node-server, lodash": "better-auth → prisma → @prisma/dev pins old versions",
    "// serialize-javascript": "vite-plugin-pwa → workbox → @rollup/plugin-terser pins ^6.0.1",
    "@hono/node-server": "1.19.11",
    "hono": "4.12.7",
    "lodash": "4.17.23",
    "serialize-javascript": "7.0.4"
  },
  "packageManager": "bun@1.3.10",
  "trustedDependencies": [
    "@swc/core",
    "@tailwindcss/oxide",
    "esbuild",
    "msw",
    "oxfmt",
    "oxlint"
  ]
}
