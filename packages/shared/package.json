{
  "name": "@openrift/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas.ts",
    "./db-field-rules": "./src/db-field-rules.ts",
    "./response-schemas": "./src/response-schemas.ts",
    "./utils": "./src/utils.ts",
    "./keywords": "./src/keywords.ts",
    "./types": "./src/types/index.ts",
    "./logger": "./src/logger.ts"
  },
  "scripts": {
    "test": "bun test $(find src -name '*.test.ts' ! -name '*.integration.test.ts')",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=./coverage $(find src -name '*.test.ts' ! -name '*.integration.test.ts')",
    "test:watch": "bun --watch test $(find src -name '*.test.ts' ! -name '*.integration.test.ts')",
    "test:integration": "bun --env-file=../../.env test $(find src -name '*.integration.test.ts')",
    "build": "tsgo",
    "typecheck": "tsgo",
    "dev": "tsgo --watch",
    "db:migrate": "bun --env-file=../../.env ../../scripts/run-migrations.ts",
    "db:rollback": "bun --env-file=../../.env ../../scripts/run-migrations.ts down",
    "make-admin": "bun --env-file=../../.env ../../scripts/make-admin.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.5.0",
    "pino": "10.3.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@typescript/native-preview": "7.0.0-dev.20260430.1",
    "typescript": "6.0.3"
  }
}
