{
  "name": "@openrift/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas.ts",
    "./db": "./src/db/index.ts",
    "./db/refresh-prices-shared": "./src/db/refresh-prices-shared.ts",
    "./db/migrate": "./src/db/migrate.ts",
    "./db/refresh-tcgplayer-prices": "./src/db/refresh-tcgplayer-prices.ts",
    "./db/refresh-cardmarket-prices": "./src/db/refresh-cardmarket-prices.ts",
    "./db/build-printing-id": "./src/db/build-printing-id.ts",
    "./db/refresh-catalog": "./src/db/refresh-catalog.ts"
  },
  "scripts": {
    "test": "bun test",
    "build": "tsc",
    "typecheck": "tsc",
    "dev": "tsc --watch",
    "db:migrate": "bun --env-file=../../.env src/db/migrate.ts",
    "db:rollback": "bun --env-file=../../.env src/db/migrate.ts down",
    "make-admin": "bun --env-file=../../.env src/db/make-admin.ts"
  },
  "dependencies": {
    "kysely": "0.28.11",
    "kysely-postgres-js": "3.0.0",
    "postgres": "3.4.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "typescript": "5.9.3"
  }
}
